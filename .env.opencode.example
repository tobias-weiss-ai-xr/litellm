# LiteLLM Proxy for OpenCode
# Copy to .env and fill in your values

# Zhipu AI (ZAI) - Primary coding provider
ZAI_API_KEY=your-zai-api-key-here
ZAI_API_BASE=https://api.z.ai/api/coding/paas/v4

# SAIA AI - Academic Cloud
SAIA_API_KEY=your-saia-api-key-here
SAIA_API_BASE=https://chat-ai.academiccloud.de/v1

# SAIA AI v2
SAIA_V2_API_KEY=your-saia-v2-api-key-here
SAIA_V2_API_BASE=https://chat-ai.academiccloud.de/v2

# Local LLM (VLLM)
LOCAL_LLM_API_KEY=none
LOCAL_LLM_API_BASE=http://192.168.0.27:8000/v1

# llama.cpp server
LLAMACPP_API_KEY=none
LLAMACPP_API_BASE=http://localhost:8080/v1

# Database (optional - for persistence)
DATABASE_URL=

# Master key for LiteLLM proxy
LITELLM_MASTER_KEY=sk-opencode-local
