x-logging: &default-logging
  driver: json-file
  options:
    max-size: "10m"
    max-file: "3"

services:
  litellm-postgres:
    image: postgres:16-alpine
    container_name: litellm-postgres
    restart: unless-stopped
    logging: *default-logging
    environment:
      POSTGRES_DB: litellm
      POSTGRES_USER: litellm
      POSTGRES_PASSWORD: litellm
    volumes:
      - litellm-pgdata:/var/lib/postgresql/data
    command: >
      postgres
      -c shared_buffers=1GB
      -c effective_cache_size=16GB
      -c work_mem=32MB
      -c maintenance_work_mem=256MB
      -c random_page_cost=1.1
      -c effective_io_concurrency=200
      -c max_connections=100
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: "2.0"
        reservations:
          memory: 512M
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U litellm -d litellm"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - litellm-net

  litellm-redis:
    image: redis:7-alpine
    container_name: litellm-redis
    restart: unless-stopped
    logging: *default-logging
    command: >
      redis-server
      --appendonly yes
      --requirepass ${REDIS_PASSWORD:-litellm}
      --maxmemory 2gb
      --maxmemory-policy allkeys-lru
    volumes:
      - litellm-redisdata:/data
    deploy:
      resources:
        limits:
          memory: 3G
          cpus: "0.5"
        reservations:
          memory: 256M
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${REDIS_PASSWORD:-litellm}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - litellm-net

  litellm-proxy:
    build:
      context: .
      dockerfile: Dockerfile.custom
    image: litellm-opencode:latest
    container_name: litellm-proxy
    restart: unless-stopped
    logging: *default-logging
    depends_on:
      litellm-postgres:
        condition: service_healthy
      litellm-redis:
        condition: service_healthy
    ports:
      - "4000:4000"
    volumes:
      - ./opencode_proxy_config.yaml:/app/config.yaml:ro
    environment:
      - LITELLM_MASTER_KEY=${LITELLM_MASTER_KEY}
      - DATABASE_URL=postgresql://litellm:litellm@litellm-postgres:5432/litellm
      - REDIS_HOST=litellm-redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=${REDIS_PASSWORD:-litellm}
      - ZAI_API_KEY=${ZAI_API_KEY}
      - ZAI_API_BASE=${ZAI_API_BASE:-https://api.z.ai/api/coding/paas/v4}
      - SAIA_API_KEY=${SAIA_API_KEY}
      - SAIA_API_BASE=${SAIA_API_BASE:-https://chat-ai.academiccloud.de/v1}
      - SAIA_V2_API_KEY=${SAIA_V2_API_KEY}
      - SAIA_V2_API_BASE=${SAIA_V2_API_BASE:-https://chat-ai.academiccloud.de/v2}
      - GOOGLE_API_KEY=${GOOGLE_API_KEY}
      - GROQ_API_KEY=${GROQ_API_KEY}
      - OPENROUTER_API_KEY=${OPENROUTER_API_KEY}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    command:
      [
        "--config",
        "/app/config.yaml",
        "--port",
        "4000",
        "--num_workers",
        "2",
        "--run_gunicorn",
      ]
    deploy:
      resources:
        limits:
          memory: 4G
          cpus: "4.0"
        reservations:
          memory: 1G
    healthcheck:
      test:
        [
          "CMD",
          "python3",
          "-c",
          "import urllib.request; urllib.request.urlopen('http://localhost:4000/health/liveliness')",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
    networks:
      - litellm-net

  dashboard:
    image: nginx:alpine
    container_name: litellm-dashboard
    restart: unless-stopped
    logging: *default-logging
    ports:
      - "3000:80"
    volumes:
      - ./dashboard/default.conf:/etc/nginx/conf.d/default.conf:ro
      - ./dashboard:/usr/share/nginx/html:ro
    extra_hosts:
      - "host.docker.internal:host-gateway"
    depends_on:
      docker-stats:
        condition: service_healthy
    deploy:
      resources:
        limits:
          memory: 128M
          cpus: "0.5"
        reservations:
          memory: 32M
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:80/api/all"]
      interval: 15s
      timeout: 10s
      retries: 3
      start_period: 10s
    networks:
      - litellm-net

  docker-stats:
    build:
      context: ./dashboard
      dockerfile: Dockerfile.stats
    image: litellm-stats-api:latest
    container_name: docker-stats-api
    restart: unless-stopped
    logging: *default-logging
    ports:
      - "3001:8000"
    environment:
      - LITELLM_MASTER_KEY=${LITELLM_MASTER_KEY}
      - PG_HOST=litellm-postgres
      - PG_PORT=5432
      - PG_DB=litellm
      - PG_USER=litellm
      - PG_PASSWORD=litellm
      - AUTO_MIGRATE=true
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./dashboard/stats.py:/app/stats.py:ro
    depends_on:
      litellm-proxy:
        condition: service_healthy
    deploy:
      resources:
        limits:
          memory: 256M
          cpus: "1.0"
        reservations:
          memory: 64M
    healthcheck:
      test:
        [
          "CMD",
          "python3",
          "-c",
          "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/docker-stats')",
        ]
      interval: 30s
      timeout: 15s
      retries: 3
      start_period: 30s
    networks:
      - litellm-net

  db-backup:
    image: postgres:16-alpine
    container_name: litellm-db-backup
    restart: "no"
    environment:
      PGHOST: litellm-postgres
      PGDATABASE: litellm
      PGUSER: litellm
      PGPASSWORD: litellm
    volumes:
      - ./backups:/backups
    entrypoint: >
      sh -c "
        mkdir -p /backups
        FILENAME=/backups/litellm_$$(date +%Y%m%d_%H%M%S).sql.gz
        echo \"Backing up to $$FILENAME ...\"
        pg_dump | gzip > $$FILENAME
        echo \"Done. Size: $$(du -h $$FILENAME | cut -f1)\"
        # Keep only the last 7 backups
        ls -t /backups/litellm_*.sql.gz | tail -n +8 | xargs -r rm --
        echo \"Cleanup complete. Kept latest 7 backups.\"
      "
    depends_on:
      litellm-postgres:
        condition: service_healthy
    networks:
      - litellm-net

networks:
  litellm-net:
    driver: bridge

volumes:
  litellm-pgdata:
  litellm-redisdata:
