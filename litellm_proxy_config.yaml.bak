model_list:
  # ── Embedding models ───────────────────────────────────────────
  - model_name: embedding
    litellm_params:
      model: openai/qwen3-embedding-4b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 30
    model_info:
      mode: embedding

  # ── SAIA (academic cloud) ───────────────────────────────────────
  # SAIA is slow and rate-limits aggressively. Use longer timeouts.
  # 429s should NOT be retried — let fallbacks handle it instead.
  - model_name: saia/mistral-large-3-675b
    litellm_params:
      model: openai/mistral-large-3-675b-instruct-2512
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/glm-4.7
    litellm_params:
      model: openai/glm-4.7
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/qwen3.5-397b-a17b
    litellm_params:
      model: openai/qwen3.5-397b-a17b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      set_reasoning_content_in_choice: true
      timeout: 1200
    model_info:
      max_input_tokens: 262144
  - model_name: saia/qwen3.5-122b-a10b
    litellm_params:
      model: openai/qwen3.5-122b-a10b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      set_reasoning_content_in_choice: true
      timeout: 900
  - model_name: saia/devstral-2-123b-instruct-2512
    litellm_params:
      model: openai/devstral-2-123b-instruct-2512
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/qwen3-coder-30b-a3b-instruct
    litellm_params:
      model: openai/qwen3-coder-30b-a3b-instruct
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/llama-3.3-70b-instruct
    litellm_params:
      model: openai/llama-3.3-70b-instruct
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/deepseek-r1-distill-llama-70b
    litellm_params:
      model: openai/deepseek-r1-distill-llama-70b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/gpt-oss-120b
    litellm_params:
      model: openai/openai-gpt-oss-120b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/qwen3.5-27b
    litellm_params:
      model: openai/qwen3.5-27b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      set_reasoning_content_in_choice: true
      timeout: 900
  - model_name: saia/qwen3.5-35b-a3b
    litellm_params:
      model: openai/qwen3.5-35b-a3b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      set_reasoning_content_in_choice: true
      timeout: 900
  - model_name: saia/apertus-70b-instruct-2509
    litellm_params:
      model: openai/apertus-70b-instruct-2509
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/gemma-3-27b-instruct
    litellm_params:
      model: openai/gemma-3-27b-it
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/teuken-7b-instruct-research
    litellm_params:
      model: openai/teuken-7b-instruct-research
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/medgemma-27b-instruct
    litellm_params:
      model: openai/medgemma-27b-it
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/llama-3.1-8b-instruct
    litellm_params:
      model: openai/meta-llama-3.1-8b-instruct
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/internvl-3.5-30b-a3b
    litellm_params:
      model: openai/internvl3.5-30b-a3b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/qwen3-30b-a3b-instruct-2507
    litellm_params:
      model: openai/qwen3-30b-a3b-instruct-2507
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900
  - model_name: saia/qwen3-omni-30b-a3b-instruct
    litellm_params:
      model: openai/qwen3-omni-30b-a3b-instruct
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 900

  # ── Groq (free tier, ultra-fast inference) ─────────────────────
  - model_name: groq/llama-3.3-70b-versatile
    litellm_params:
      model: groq/llama-3.3-70b-versatile
      api_key: os.environ/GROQ_API_KEY
    model_info:
      supports_reasoning: false
  - model_name: groq/gemma2-9b-it
    litellm_params:
      model: groq/gemma2-9b-it
      api_key: os.environ/GROQ_API_KEY
    model_info:
      supports_reasoning: false
  - model_name: groq/mixtral-8x7b-32768
    litellm_params:
      model: groq/mixtral-8x7b-32768
      api_key: os.environ/GROQ_API_KEY
    model_info:
      supports_reasoning: false

  # ── OpenRouter (free models) ────────────────────────────────────
  - model_name: openrouter/llama-4-maverick
    litellm_params:
      model: openrouter/meta-llama/llama-4-maverick:free
      api_key: os.environ/OPENROUTER_API_KEY
  - model_name: openrouter/deepseek-r1
    litellm_params:
      model: openrouter/deepseek/deepseek-r1-0528:free
      api_key: os.environ/OPENROUTER_API_KEY
  - model_name: openrouter/gemini-2.0-flash
    litellm_params:
      model: openrouter/google/gemini-2.0-flash-exp:free
      api_key: os.environ/OPENROUTER_API_KEY
  - model_name: openrouter/qwen-2.5-72b
    litellm_params:
      model: openrouter/qwen/qwen-2.5-72b-instruct:free
      api_key: os.environ/OPENROUTER_API_KEY

  # ── Local models ────────────────────────────────────────────────
  # qwen3.5-397b via AI cluster (LAN, no VPN needed)
  # NOTE: --served-model-name added to systemd template but cluster needs restart.
  # Using openai//models as safe fallback (works regardless of served-model-name).
  # Once cluster is confirmed running with --served-model-name, change to openai/qwen3.5-397b-a17b
  # - model_name: qwen3.5-397b
  #   litellm_params:
  #     model: openai//models
  #     api_key: not-needed
  #     api_base: http://192.168.0.27:8000/v1
  #   model_info:
  #     max_input_tokens: 262144
  #     max_output_tokens: 65536

  # gemma-4-26b-nvfp4 via vLLM on ai1 + Windows llama.cpp (load-balanced, failover)
  # NOTE: ai2 (192.168.0.176) now runs Qwen3.6-35B-A3B-FP8 (see qwen3.6-35b-a3b below)
  # vLLM backends don't support tool calling — disables to prevent cooldown cascades
  - model_name: gemma-4-26b-nvfp4
    litellm_params:
      model: openai/gemma-4-26b
      api_key: not-needed
      api_base: http://192.168.0.27:8000/v1
      litellm_model_id: gemma-4-26b
      timeout: 300
      stream_timeout: 600
    model_info:
      max_input_tokens: 262144
      max_output_tokens: 131072
      supports_tool_calling: false
      supports_reasoning: false
  - model_name: gemma-4-26b-nvfp4
    litellm_params:
      model: openai/google_gemma-4-26B-A4B-it-Q4_K_M.gguf
      api_key: not-needed
      api_base: http://host.docker.internal:8080/v1
      timeout: 300
      stream_timeout: 60
      drop_params: true
    model_info:
      supports_tool_calling: false
      supports_reasoning: false

  # Qwen3.6-35B-A3B-FP8 via vLLM on ai2 (replaced gemma-4-26b on this server)
  - model_name: qwen3.6-35b
    litellm_params:
      model: openai/qwen3.6-35b
      api_key: not-needed
      api_base: http://192.168.0.176:8000/v1
      timeout: 300
      stream_timeout: 600
    model_info:
      max_input_tokens: 262144
      max_output_tokens: 65536
      supports_tool_calling: false
      supports_reasoning: false
  

  # gemma-4-e2b via llama.cpp on legion (smaller/faster for quick tasks)
  - model_name: gemma-4-e2b
    litellm_params:
      model: openai/google_gemma-4-E2B-it-Q8_0.gguf
      api_key: not-needed
      api_base: http://192.168.0.81:8080/v1
      timeout: 300
      stream_timeout: 120
      drop_params: true
    model_info:
      supports_tool_calling: false
      supports_reasoning: false
      max_input_tokens: 32768

  # ── Round-robin: ai1 (gemma-4-26b) + ai2 (qwen3.6-35b) ─────────
  # Same model_name on multiple entries = LiteLLM router load-balances
  - model_name: local-ai
    litellm_params:
      model: openai/gemma-4-26b
      api_key: not-needed
      api_base: http://192.168.0.27:8000/v1
      litellm_model_id: gemma-4-26b
      timeout: 300
      stream_timeout: 600
    model_info:
      max_input_tokens: 262144
      max_output_tokens: 131072
      supports_tool_calling: false
      supports_reasoning: false
  - model_name: local-ai
    litellm_params:
      model: openai/qwen3.6-35b
      api_key: not-needed
      api_base: http://192.168.0.176:8000/v1
      timeout: 300
      stream_timeout: 600
    model_info:
      max_input_tokens: 262144
      max_output_tokens: 65536
      supports_tool_calling: false
      supports_reasoning: false

  # qwen3.5-9b for explore agent (fast contextual grep via SAIA)
  - model_name: qwen3.5-9b
    litellm_params:
      model: openai/qwen3.5-9b
      api_key: os.environ/SAIA_API_KEY
      api_base: https://chat-ai.academiccloud.de/v1
      timeout: 300


  # ── Local models (ai1: vLLM Gemma-4-26B, ai2: SGLang Qwen3.6-35B) ──
  - model_name: gemma-4-26b/ai1
    litellm_params:
      model: openai/gemma-4-26b
      api_key: not-needed
      api_base: http://192.168.0.27:8000/v1
      timeout: 300
      stream_timeout: 60
    model_info:
      max_input_tokens: 262144
      max_output_tokens: 131072
  - model_name: qwen3.6-35b/ai2
    litellm_params:
      model: openai//root/.cache/huggingface/hub/models--Qwen--Qwen3.6-35B-A3B-FP8
      api_key: not-needed
      api_base: http://192.168.0.176:8000/v1
      timeout: 300
      stream_timeout: 60
    model_info:
      max_input_tokens: 262144
  - model_name: gemma-4-26b
    litellm_params:
      model: openai/gemma-4-26b
      api_key: not-needed
      api_base: http://192.168.0.27:8000/v1
      timeout: 300
      stream_timeout: 60
    model_info:
      max_input_tokens: 262144
      max_output_tokens: 131072

general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY
  database_url: os.environ/DATABASE_URL

router_settings:
  enable_pre_call_checks: false
  fallbacks:
    # ── All models → local gemma-4-26b only ────────────────────────
    # CRITICAL FIX: Simple non-circular fallback chain
    # gemma-4-26b-nvfp4 → gemma-4-26b (no circular references)
    - gemma-4-26b-nvfp4: [gemma-4-26b]
    # All qwen3.6 variants fallback ONLY to gemma-4-26b (no alternative qwen models)
    - qwen3.6-35b: [gemma-4-26b]
    - qwen3.6-35b/ai2: [gemma-4-26b]
    # SAIA models fallback to local gemma (no circular qwen chains)
    - saia/qwen3.5-397b-a17b: [gemma-4-26b]
    - saia/mistral-large-3-675b: [gemma-4-26b]
    - saia/glm-4.7: [gemma-4-26b]
    - saia/qwen3.5-122b-a10b: [gemma-4-26b]
    - saia/qwen3.5-35b-a3b: [gemma-4-26b]
    - saia/devstral-2-123b-instruct-2512: [gemma-4-26b]
    - saia/qwen3-coder-30b-a3b-instruct: [gemma-4-26b]
    - saia/llama-3.3-70b-instruct: [gemma-4-26b]
    - saia/deepseek-r1-distill-llama-70b: [gemma-4-26b]
    - saia/gpt-oss-120b: [gemma-4-26b]
    - saia/qwen3.5-27b: [gemma-4-26b]
    - saia/apertus-70b-instruct-2509: [gemma-4-26b]
    - saia/gemma-3-27b-instruct: [gemma-4-26b]
    - saia/teuken-7b-instruct-research: [gemma-4-26b]
    - saia/medgemma-27b-instruct: [gemma-4-26b]
    - saia/llama-3.1-8b-instruct: [gemma-4-26b]
    - saia/internvl-3.5-30b-a3b: [gemma-4-26b]
    - saia/qwen3-30b-a3b-instruct-2507: [gemma-4-26b]
    - saia/qwen3-omni-30b-a3b-instruct: [gemma-4-26b]
    - groq/llama-3.3-70b-versatile: [gemma-4-26b]
    - groq/gemma2-9b-it: [gemma-4-26b]
    - groq/mixtral-8x7b-32768: [gemma-4-26b]
    - openrouter/llama-4-maverick: [gemma-4-26b]
    - openrouter/deepseek-r1: [gemma-4-26b]
    - openrouter/gemini-2.0-flash: [gemma-4-26b]
    - openrouter/qwen-2.5-72b: [gemma-4-26b]
    - qwen3.5-9b: [gemma-4-26b]
    - gemma-4-e2b: [gemma-4-26b]
    - local-ai: [gemma-4-26b]
    - gemma-4-26b/ai1: [gemma-4-26b]
  routing_strategy: least-busy
  num_retries: 2
  retry_after: 5
  allowed_fails: 5
  cooldown_time: 30
  allowed_fails_policy:
    RateLimitErrorAllowedFails: 10
    TimeoutErrorAllowedFails: 3
  retry_policy:
    AuthenticationErrorRetries: 0
    ContentPolicyViolationErrorRetries: 0
    BadRequestErrorRetries: 0
    TimeoutErrorRetries: 3
    RateLimitErrorRetries: 3

litellm_settings:
  request_timeout: 600
  read_timeout: 300
  drop_params: true
  telemetry: false
  cache: true
  cache_params:
    type: redis
    host: os.environ/REDIS_HOST
    port: os.environ/REDIS_PORT
    password: os.environ/REDIS_PASSWORD
    ttl: 3600
  client_session_args:
    keep_alive_expiry: 300
    max_connections: 200
    max_keepalive_connections: 40
